<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema Utama Aplikasi -->
    <style name="Base.Theme.UAS202404021" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.UAS202404021" parent="Base.Theme.UAS202404021" />

    <!-- Tema Khusus untuk Splash Screen API -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background Splash Screen -->
        <item name="windowSplashScreenBackground">?android:attr/colorBackground</item>
        
        <!-- Ikon Tengah (menggunakan ikon inventory atau ikon launcher) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_inventory</item>
        
        <!-- Tema tujuan setelah splash selesai loading -->
        <item name="postSplashScreenTheme">@style/Theme.UAS202404021</item>
    </style>
</resources>